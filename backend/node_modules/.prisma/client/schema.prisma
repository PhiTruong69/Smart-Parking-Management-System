generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          String   @id
  name        String
  role        String
  program     String?
  status      String
  parkingPass String?
  balance     Int      @default(0)
  entryCount  Int      @default(0)
  createdAt   DateTime @default(now())
}

model ParkingZone {
  id       String @id
  name     String
  total    Int
  occupied Int
}

model ParkingSession {
  id        String    @id
  userId    String?
  zoneId    String
  gate      String
  vehicleId String?
  method    String
  entryAt   DateTime
  exitAt    DateTime?
  status    String
  fee       Int?
}

model Ticket {
  ticketNo String   @id
  issuedAt DateTime
  zoneId   String
  gate     String
  note     String?
  status   String
}

model Transaction {
  id       String   @id
  userId   String
  userName String
  type     String
  amount   Int
  period   String
  status   String
  date     DateTime
  method   String
}

# Server Configuration
PORT=5000
NODE_ENV=development

# Database
DATABASE_URL="postgresql://parking_user:parking_password@localhost:5432/smart_parking"

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_change_in_production_12345678
JWT_EXPIRE=8h
REFRESH_TOKEN_SECRET=your_refresh_token_secret_change_in_production_87654321
REFRESH_TOKEN_EXPIRE=7d

# HCMUT SSO Configuration
HCMUT_SSO_CLIENT_ID=your_client_id_from_hcmut
HCMUT_SSO_CLIENT_SECRET=your_client_secret_from_hcmut
HCMUT_SSO_AUTHORIZE_URL=https://sso.hcmut.edu.vn/oauth/authorize
HCMUT_SSO_TOKEN_URL=https://sso.hcmut.edu.vn/oauth/token
HCMUT_SSO_USER_INFO_URL=https://sso.hcmut.edu.vn/oauth/userinfo
HCMUT_SSO_CALLBACK_URL=http://localhost:5000/api/auth/sso-callback

# HCMUT DATACORE Configuration (Read-only)
HCMUT_DATACORE_API=https://datacore.hcmut.edu.vn/api
HCMUT_DATACORE_API_KEY=your_datacore_api_key_change_in_production

# BKPay Integration
BKPAY_API=https://bkpay.hcmut.edu.vn/api
BKPAY_SECRET=your_bkpay_secret_change_in_production
BKPAY_MERCHANT_ID=parking_system

# IoT Gateway
IOT_GATEWAY_URL=http://localhost:1883
IOT_MQTT_TOPIC_PREFIX=parking/zones

# Logging
LOG_LEVEL=info
